  Content-Security-Policy: default-src 'self'; base-uri 'self'; frame-ancestors 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; script-src 'self' 'unsafe-inline' https://portal.bensky.co.uk; connect-src 'self' https://api.web3forms.com https://portal.bensky.co.uk; frame-src https://portal.bensky.co.uk; form-action 'self' https://api.web3forms.com
